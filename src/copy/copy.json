        "title": "Cache hit rate fell on {project} ({tool})",
        "body": "Last 7 days {recent} vs prior 30 days {prior} (drop {drop}). Reusing the warm prompt cache would have helped.",
        "assumption": "Pricing assumes the model's cache_read tier; 5-minute TTL means short gaps lose the cache."
      },
      "cache_write_overhead": {
        "title": "Cache writes outpace reads for {tool}",
        "body": "Write-to-read ratio is {ratio} over {events} recent events — sessions are creating cache they don't reuse.",
        "assumption": "Pricing uses cache_write minus cache_read deltas. Longer sessions amortise cache writes."
      },
      "low_hit_project_outlier": {
        "title": "{project} has a low cache hit rate vs your {tool} median",
        "body": "Hit rate {rate} vs tool median {median} across {sessions} sessions in the last 7 days.",
        "assumption": "Median is computed from your other projects on the same tool."
      },
      "cache_tool_silenced": {
        "title": "Cache rules skipped for {tool}",
        "body": "{tool} doesn't expose cache_read/write metrics locally, so cache recommendations can't be computed.",
        "assumption": "This is a data-source gap, not a usage problem."
      },
      "outlier_session_cost": {
        "title": "Session {session} cost {cost} on {project}",
        "body": "Above the {threshold} outlier threshold (P95 / Q3+1.5·IQR over the last 30 days).",
        "assumption": "Investigate the session in the Session page to confirm it was intentional."
      },
      "day_over_day_spend_zscore": {
        "title": "Today's spend is {delta_pct} above your 30-day baseline",
        "body": "Today {today} vs baseline {baseline} (z-score {zscore}).",
        "assumption": "Baseline uses the trailing 30-day mean/stdev across all tools."
      },
