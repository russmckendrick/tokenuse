{
  "$schema": "./gen/schemas/desktop-schema.json",
  "productName": "Token Use",
  "version": "0.0.5",
  "identifier": "com.russmckendrick.tokenuse",
  "build": {
    "beforeDevCommand": "pnpm run dev",
    "beforeBuildCommand": "pnpm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "Token Use",
        "width": 1280,
        "height": 860,
        "minWidth": 1040,
        "minHeight": 720,
        "theme": "Dark"
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'",
      "capabilities": ["default"]
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "publisher": "Russ McKendrick",
    "homepage": "https://www.tokenuse.app",
    "category": "DeveloperTool",
    "shortDescription": "Desktop app for local AI coding tool token and cost usage",
    "longDescription": "Token Use is a local-only desktop app for exploring AI coding tool token and cost usage. It reads local usage files directly and shares its archive and configuration with the tokenuse terminal UI.",
    "license": "MIT",
    "copyright": "Copyright 2026 Russ McKendrick",
    "macOS": {
      "bundleName": "Token Use",
      "files": {
        "Resources/Credits.rtf": "Credits.rtf"
      }
    }
  }
}
